# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nigeria-attack-tracker?retryWrites=true&w=majority

# Gemini API Key (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Default Admin Bootstrap (used only when no users exist)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_this_strong_password

# Cron Job Secret (set this to a strong random string, use the same in cron-job.org headers)
CRON_SECRET=your_cron_secret_here

# API Key for public endpoints
API_KEY=your_api_key_here

# JWT secret for admin auth
JWT_SECRET=replace_with_long_random_secret
# Optional: bump to invalidate existing sessions
JWT_SECRET_VERSION=1

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App URL (for CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Twitter/X Scraper Credentials (use a secondary/burner account — risk of ban)
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_EMAIL=your_twitter_email@example.com
# Optional: paste cookie JSON here after first successful login to avoid re-login
# TWITTER_COOKIES=
